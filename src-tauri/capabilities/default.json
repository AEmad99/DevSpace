{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "local": true,
  "remote": {
    "urls": ["http://127.0.0.1:*/*", "http://localhost:*/*"]
  },
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "notification:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "http://127.0.0.1:*/*" },
        { "url": "http://localhost:*/*" }
      ]
    }
  ]
}
